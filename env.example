# ── Which account this service is. Pick ONE per Railway service ──
#   ftmo_demo | ftmo_eval | maven | vantage | fundednext
FIRM=ftmo_demo

# ── TradingView webhook auth (SAME value on every service) ──
WEBHOOK_SECRET=change_me_same_on_all

# ── MetaAPI (per account) ──
META_API_TOKEN=your-metaapi-token
META_ACCOUNT=your-metaapi-account-id
META_BASE=https://mt-client-api-v1.agiliumtrade.ai

# ── Database (auto-set by the Railway Postgres plugin) ──
DATABASE_URL=

# ── Optional: size trades off a fixed equity instead of live balance ──
# e.g. size a tiny demo like a 50k account. Leave blank to use live equity.
RISK_EQUITY=

# ── Model gate (feature 10): off | shadow | live ──
#   shadow (default) logs what the model would decide but never blocks.
#   Set to "live" only once a real model is trusted. Leave as shadow for now.
MODEL_MODE=shadow

# Auto-set by Railway
PORT=3000

# ── Ghost reaper (guaranteed finalize) ──
# A ghost is force-finalized (negatives backfilled, data_complete=false) if it
# gets no price update for GHOST_STALE_MIN minutes, or outlives GHOST_MAX_HOURS.
# Guarantees no ghost is ever lost to a MetaAPI outage or a trade that never
# returns to its stop. Defaults are fine.
GHOST_STALE_MIN=90
GHOST_MAX_HOURS=72
